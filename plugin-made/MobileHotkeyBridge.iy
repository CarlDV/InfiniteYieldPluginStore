iptCmd = Instance.new("TextBox"); iptCmd.PlaceholderText="e.g. fly 50"; iptCmd.Size=UDim2.new(1,-40,0,32); iptCmd.Position=UDim2.new(0,20,0,90); iptCmd.BackgroundColor3=Color3.fromRGB(25,25,28); iptCmd.TextColor3=Color3.fromRGB(240,240,240); iptCmd.Font=Enum.Font.Code; iptCmd.TextSize=12; iptCmd.ClearTextOnFocus=false; iptCmd.TextXAlignment=Enum.TextXAlignment.Left; local p4=Instance.new("UIPadding"); p4.PaddingLeft=UDim.new(0,8); p4.Parent=iptCmd; cr(4).Parent=iptCmd; st(Color3.fromRGB(45,45,50)).Parent=iptCmd; iptCmd.Parent=impC; iptCmd.ZIndex=12

local l3 = Instance.new("TextLabel"); l3.Text="Untoggle Cmd (Optional)"; l3.Size=UDim2.new(1,-40,0,20); l3.Position=UDim2.new(0,20,0,130); l3.TextColor3=Color3.fromRGB(120,120,120); l3.Font=Enum.Font.GothamBold; l3.TextSize=10; l3.BackgroundTransparency=1; l3.TextXAlignment=Enum.TextXAlignment.Left; l3.Parent=impC; l3.ZIndex=12
iptUncmd = Instance.new("TextBox"); iptUncmd.PlaceholderText="e.g. unfly"; iptUncmd.Size=UDim2.new(1,-40,0,32); iptUncmd.Position=UDim2.new(0,20,0,150); iptUncmd.BackgroundColor3=Color3.fromRGB(25,25,28); iptUncmd.TextColor3=Color3.fromRGB(240,240,240); iptUncmd.Font=Enum.Font.Code; iptUncmd.TextSize=12; iptUncmd.ClearTextOnFocus=false; iptUncmd.TextXAlignment=Enum.TextXAlignment.Left; local p5=Instance.new("UIPadding"); p5.PaddingLeft=UDim.new(0,8); p5.Parent=iptUncmd; cr(4).Parent=iptUncmd; st(Color3.fromRGB(45,45,50)).Parent=iptUncmd; iptUncmd.Parent=impC; iptUncmd.ZIndex=12

local btnCS = Instance.new("TextButton"); btnCS.Text="Cancel"; btnCS.Size=UDim2.new(0.5,-25,0,32); btnCS.Position=UDim2.new(0,20,1,-42); btnCS.BackgroundColor3=Color3.fromRGB(35,35,40); btnCS.TextColor3=Color3.fromRGB(220,220,220); btnCS.Font=Enum.Font.GothamMedium; btnCS.TextSize=12; btnCS.ZIndex=12; cr(4).Parent=btnCS; btnCS.Parent=impC
btnSaveEdit = Instance.new("TextButton"); btnSaveEdit.Text="Save"; btnSaveEdit.Size=UDim2.new(0.5,-25,0,32); btnSaveEdit.Position=UDim2.new(0.5,5,1,-42); btnSaveEdit.BackgroundColor3=Color3.fromRGB(0,140,255); btnSaveEdit.TextColor3=Color3.fromRGB(255,255,255); btnSaveEdit.Font=Enum.Font.GothamMedium; btnSaveEdit.TextSize=12; btnSaveEdit.ZIndex=12; cr(4).Parent=btnSaveEdit; btnSaveEdit.Parent=impC

btnCS.MouseButton1Click:Connect(function() editWin.Visible = false end)
btnSaveEdit.MouseButton1Click:Connect(function()
    if iptName.Text == "" or iptCmd.Text == "" then return end
    if currentEditIndex then
        local p = hotkeyData[currentEditIndex].pos
        local s = hotkeyData[currentEditIndex].state
        hotkeyData[currentEditIndex] = {name=iptName.Text, cmd=iptCmd.Text, uncmd=iptUncmd.Text, pos=p, state=s}
    else
        table.insert(hotkeyData, {name=iptName.Text, cmd=iptCmd.Text, uncmd=iptUncmd.Text, pos=nil, state=false})
    end
    saveConfig()
    renderList()
    drawHUD()
    editWin.Visible = false
end)

btnNew.MouseButton1Click:Connect(function()
    currentEditIndex = nil
    iptName.Text = ""
    iptCmd.Text = ""
    iptUncmd.Text = ""
    editWin.Visible = true
end)

renderList()
drawHUD()

local Plugin = {
    ["PluginName"] = "Mobile Hotkey Bridge",
    ["PluginDescription"] = "Customizable floating hotkey buttons for quick command execution on mobile devices.",
    ["Commands"] = {
        ["hotkeys"] = {
            ["ListName"] = "hotkeys / hb",
            ["Description"] = "Open the Mobile Hotkey editor UI",
            ["Aliases"] = {"hb", "hotkeybridge"},
            ["Function"] = function(args, speaker)
                if win.Visible then
                    playAnim(win, false)
                else
                    playAnim(win, true)
                end
            end
        }
    }
}

return Plugin
