listContainer.Parent = win

local function saveConfig()
    if hasFS then
        pcall(function() writefile(saveFile, HS:JSONEncode(hotkeyData)) end)
    end
end

local editWin, iptName, iptCmd, iptUncmd, btnSaveEdit
local currentEditIndex = nil

local function execute(cmdStr)
    local succ = pcall(function()
        if typeof(execCmd) == "function" then
            execCmd(cmdStr)
        elseif typeof(game:GetService("Players").LocalPlayer) then
            local prefix = (typeof(getgenv) == "function" and getgenv().prefix) or ";"
            if cmdStr:sub(1, #prefix) ~= prefix then cmdStr = prefix .. cmdStr end
            local chatRemote = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
            if chatRemote then
                chatRemote:FindFirstChild("SayMessageRequest"):FireServer(cmdStr, "All")
            else
                game:GetService("TextChatService").TextChannels.RBXGeneral:SendAsync(cmdStr)
            end
        end
    end)
end

local function drawHUD()
    for _, c in pairs(actionHUD:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    for i, hk in ipairs(hotkeyData) do
        local btn = Instance.new("TextButton")
        btn.Text = hk.name:sub(1,8)
        
        if hk.pos then
            btn.Position = UDim2.new(hk.pos[1], hk.pos[2], hk.pos[3], hk.pos[4])
        else
            btn.Position = UDim2.new(0.8, 0, 0.2 + (i * 0.1), 0)
        end
        
        btn.Size = UDim2.new(0, 42, 0, 42)
        if hk.state then
            btn.BackgroundColor3 = Color3.fromRGB(0, 140, 255)
        else
            btn.BackgroundColor3 = Color3.fromRGB(22,22,25)
        end
        
        btn.TextColor3 = Color3.fromRGB(240,240,240)
        btn.Font = Enum.Font.GothamBold; btn.TextSize = 9
        btn.ClipsDescendants = true; btn.AutoButtonColor = true
        cr(21).Parent=btn
        st(Color3.fromRGB(45,45,50)).Parent=btn
        
        dragGUI(btn, function(newPos)
            hk.pos = {newPos.X.Scale, newPos.X.Offset, newPos.Y.Scale, newPos.Y.Offset}
            saveConfig()
        end, function()
            if hk.uncmd and hk.uncmd ~= "" then
                if hk.state then
                    hk.state = false
                    execute(hk.uncmd)
                    btn.BackgroundColor3 = Color3.fromRGB(22,22,25)
                else
                    hk.state = true
                    execute(hk.cmd)
                    btn.BackgroundColor3 = Color3.fromRGB(0,140,255)
                end
            else
                execute(hk.cmd)
                btn.BackgroundColor3 = Color3.fromRGB(0,140,255)
                task.delay(0.2, function() btn.BackgroundColor3 = Color3.fromRGB(22,22,25) end)
            end
        end)
        
        btn.Parent = actionHUD
    end
end

local function renderList()
    for _, c in pairs(listContainer:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    for i, hk in ipairs(hotkeyData) do
        local f = Instance.new("Frame"); f.Size=UDim2.new(1,0,0,46); f.BackgroundColor3=Color3.fromRGB(22,22,26); cr(4).Parent=f; st(Color3.fromRGB(45,45,50)).Parent=f
		local lblN = Instance.new("TextLabel"); lblN.Text=hk.name; lblN.Size=UDim2.new(1,-70,0,18); lblN.Position=UDim2.new(0,8,0,6); lblN.TextColor3=Color3.fromRGB(240,240,240); lblN.BackgroundTransparency=1; lblN.Font=Enum.Font.GothamMedium; lblN.TextSize=12; lblN.TextXAlignment=Enum.TextXAlignment.Left; lblN.TextTruncate=Enum.TextTruncate.AtEnd; lblN.Parent=f
		local lblK = Instance.new("TextLabel"); lblK.Text="Cmd: " .. hk.cmd; lblK.Size=UDim2.new(1,-70,0,14); lblK.Position=UDim2.new(0,8,0,24); lblK.TextColor3=Color3.fromRGB(120,120,120); lblK.BackgroundTransparency=1; lblK.Font=Enum.Font.Code; lblK.TextSize=10; lblK.TextXAlignment=Enum.TextXAlignment.Left; lblK.TextTruncate=Enum.TextTruncate.AtEnd; lblK.Parent=f
        
        local bEdit = Instance.new("TextButton"); bEdit.Text="Edit"; bEdit.Size=UDim2.new(0,34,0,22); bEdit.Position=UDim2.new(1,-72,0.5,-11); bEdit.BackgroundColor3=Color3.fromRGB(40,40,45); bEdit.TextColor3=Color3.fromRGB(220,220,220); bEdit.Font=Enum.Font.GothamMedium; bEdit.TextSize=10; cr(4).Parent=bEdit; bEdit.Parent=f
		
		local bDel = Instance.new("TextButton"); bDel.Text="×"; bDel.Size=UDim2.new(0,26,0,22); bDel.Position=UDim2.new(1,-34,0.5,-11); bDel.BackgroundColor3=Color3.fromRGB(255,100,100); bDel.TextColor3=Color3.fromRGB(255,255,255); bDel.Font=Enum.Font.GothamBold; bDel.TextSize=14; cr(4).Parent=bDel; bDel.Parent=f
		
        bEdit.MouseButton1Click:Connect(function()
            currentEditIndex = i
            iptName.Text = hk.name
            iptCmd.Text = hk.cmd
            iptUncmd.Text = hk.uncmd or ""
            editWin.Visible = true
        end)

        bDel.MouseButton1Click:Connect(function()
			table.remove(hotkeyData, i)
			renderList(); drawHUD(); saveConfig()
		end)

        f.Parent = listContainer
    end
end

