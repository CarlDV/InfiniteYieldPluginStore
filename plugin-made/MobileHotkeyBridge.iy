btnNew.BackgroundColor3=Color3.fromRGB(0,140,255); btnNew.TextColor3=Color3.fromRGB(255,255,255); btnNew.Font=Enum.Font.GothamMedium; btnNew.TextSize=11; cr(4).Parent=btnNew
