iptName = Instance.new("TextBox"); iptName.PlaceholderText="e.g. Fly"; iptName.Size=UDim2.new(1,-40,0,32); iptName.Position=UDim2.new(0,20,0,30); iptName.BackgroundColor3=Color3.fromRGB(25,25,28); iptName.TextColor3=Color3.fromRGB(240,240,240); iptName.Font=Enum.Font.Gotham; iptName.TextSize=12; iptName.ClearTextOnFocus=false; iptName.TextXAlignment=Enum.TextXAlignment.Left; local p3=Instance.new("UIPadding"); p3.PaddingLeft=UDim.new(0,8); p3.Parent=iptName; cr(4).Parent=iptName; st(Color3.fromRGB(45,45,50)).Parent=iptName; iptName.Parent=impC; iptName.ZIndex=12

